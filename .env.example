# Required
SECRET_KEY=generate-a-random-64-char-string-here

# Ollama (already configured for your cloud)
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gemma3:27b
OLLAMA_API_KEY=your-key-here

